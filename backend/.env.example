# Java backend env değişkenleri
# Aşağıdaki anahtarı sisteme env variable olarak set edin:
#   Windows (PowerShell):  $env:ANTHROPIC_API_KEY="sk-ant-..."
#   Windows (cmd):         set ANTHROPIC_API_KEY=sk-ant-...
#   Linux/Mac:             export ANTHROPIC_API_KEY=sk-ant-...
#
# Veya application.yml içindeki ${ANTHROPIC_API_KEY:...} default'unu değiştirin.

ANTHROPIC_API_KEY=sk-ant-...
