# Hackathon Environment Variables
# ─────────────────────────────────────────
# Java backend için sistem environment variable olarak set edin:
#   Windows (PowerShell):  $env:ANTHROPIC_API_KEY="sk-ant-..."
#   Windows (cmd):         set ANTHROPIC_API_KEY=sk-ant-...
#   Linux/Mac:             export ANTHROPIC_API_KEY=sk-ant-...
#
# Alternatif: backend/src/main/resources/application.yml içindeki
# ${ANTHROPIC_API_KEY:...} default'unu doğrudan değiştirin.

ANTHROPIC_API_KEY=sk-ant-...

# Frontend (Vite proxy zaten backend port 3001'e bağlı, değiştirmenize gerek yok)
# VITE_API_URL=http://localhost:3001
